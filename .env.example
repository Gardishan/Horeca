APP_ENV="development"
DEPLOYMENT_VERSION="local"
DATABASE_URL="postgresql://horeca:horeca@localhost:5432/horeca?schema=public"
AUTH_SECRET="replace-with-at-least-32-random-characters"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Local development and tests only. Staging/production must use s3.
PRIVATE_STORAGE_MODE="filesystem"
PRIVATE_STORAGE_ROOT="./storage/private"
PRIVATE_STORAGE_S3_ENDPOINT=""
PRIVATE_STORAGE_S3_REGION=""
PRIVATE_STORAGE_S3_BUCKET=""
PRIVATE_STORAGE_S3_FORCE_PATH_STYLE=""
PRIVATE_STORAGE_S3_SSE=""
PRIVATE_STORAGE_S3_KMS_KEY_ID=""
# Optional for local S3. Prefer workload identity in deployed environments.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
DEMO_AUTH_ENABLED="true"
# Local development only. Production must leave memory mode disabled and configure the HTTPS backend.
RATE_LIMIT_MODE="memory"
RATE_LIMIT_ALLOW_IN_MEMORY="false"
RATE_LIMIT_BACKEND_URL=""
RATE_LIMIT_BACKEND_TOKEN=""
# Local development only. Staging/production must use the documented HTTPS scanner.
MALWARE_SCAN_MODE="mock"
MALWARE_SCAN_BACKEND_URL=""
MALWARE_SCAN_BACKEND_TOKEN=""
MALWARE_SCAN_TIMEOUT_MS=""
