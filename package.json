{
  "name": "horeca-kz",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check:repo": "node scripts/check-repository.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "smoke:http": "node scripts/smoke-http.mjs",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "quality:quick": "npm run check:repo && npm run typecheck && npm run test && npm run lint",
    "verify": "npm run check:repo && npm run prisma:validate && npm run typecheck && npm run test:coverage && npm run lint && npm run build",
    "validate": "npm run verify",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.3",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "dotenv": "17.4.2",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prisma": "6.19.3",
    "tailwindcss": "4.3.3",
    "tsx": "^4.20.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
